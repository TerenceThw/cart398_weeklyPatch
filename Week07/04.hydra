osc(30,.5,.5).color(()=>time%1,5,15).hue(()=>Math.sin(time)).pixelate(20,5).out(o0)
osc(10,.02,5).mask(o0).saturate(5).out(o1)
src(o0).blend(o3, ()=>Math.sin(time)*0.5+0.5).modulateScrollX(o2,.005).colorama(.01).contrast(1.2).out(o2)
shape(4,.6,.01).mult(o2).hue(()=>Math.sin(time)*0.05+0.5).modulateRepeatX(o3,4).contrast(1.2).out(o3)
render(o3)
