await initHydra()

noise(500)
  .color(1.5,2,5)
  .modulateRotate(noise(2).pixelate(5,5)).out(o1)
  src(o0).blend(shape(4).g().thresh().scrollX(.1,.1).mult(o1).invert([-1,1]),0.05)
     //.thresh()
      .invert([-1,1],)
      .out(o0)
